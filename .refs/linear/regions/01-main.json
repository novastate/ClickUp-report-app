      {
        "level": 1,
        "text": "system for teams and agents",
        "fontSize": 64,
        "source": "inferred",
        "bbox": {
          "x": 78,
          "y": 336,
          "w": 784,
          "h": 64
        }
      },
      {
        "level": 2,
        "text": "A new species of product tool. Purpose-built for modern teams with AI workflows at its core, Linear sets a new standard for planning and building products.",
        "fontSize": 48,
        "source": "explicit",
        "bbox": {
          "x": 46,
          "y": 1532,
          "w": 1250,
          "h": 144
        }
      },
      {
        "level": 2,
        "text": "Make product operations self-driving",
        "fontSize": 48,
        "source": "explicit",
        "bbox": {
          "x": 78,
          "y": 2578,
          "w": 542,
          "h": 96
        }
      },
      {
        "level": 2,
        "text": "Define the product direction",
        "fontSize": 48,
        "source": "explicit",
        "bbox": {
          "x": 78,
          "y": 3795,
          "w": 542,
          "h": 96
        }
      },
      {
        "level": 2,
        "text": "Move work forward across teams and agents",
        "fontSize": 48,
        "source": "explicit",
        "bbox": {
          "x": 78,
          "y": 5003,
          "w": 542,
          "h": 96
        }
      }
    ],
    "paragraphs": [
      {
        "text": "Purpose-built for planning and building products. Designed for the AI era.",
        "fontSize": 15
      },
      {
        "text": "Render UI before vehicle_state sync when minimum required state is present, instead of blocking on full refresh during iOS startup.",
        "fontSize": 14
      },
      {
        "text": "Linear is shaped by the practices and principles of world-class product teams.",
        "fontSize": 15
      },
      {
        "text": "Designed for workflows shared by humans and agents. From drafting PRDs to pushing PRs.",
        "fontSize": 15
      },
      {
        "text": "Reduces noise and restores momentum to help teams ship with high velocity and focus.",
        "fontSize": 15
      },
      {
        "text": "Turn conversations and customer feedback into actionable issues that are routed, labeled, and prioritized for the right team.",
        "fontSize": 24
      },
      {
        "text": "Plan and navigate from idea to launch. Align your team with product initiatives, strategic roadmaps, and clear, up-to-date PRDs.",
        "fontSize": 24
      },
      {
        "text": "Build and deploy AI agents that work alongside your team. Work on complex tasks together or delegate entire issues end-to-end.",
        "fontSize": 24
      }
    ],
